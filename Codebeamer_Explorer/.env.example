# ============================================================
# Codebeamer 連線（必填）
# 複製此檔為 .env 並填入實際值，勿提交 .env 到版控
# ============================================================
# 範例: CB_BASE_URL=https://almqa.realtek.com/cb/rest/v3
CB_BASE_URL=https://your-cb-host/cb/rest/v3

# 範例: CB_USERNAME=your_username
CB_USERNAME=your_username
# 範例: CB_PASSWORD=your_password
CB_PASSWORD=your_password
# 若改用 Token 認證，填 CB_TOKEN 並註解掉上面 CB_USERNAME / CB_PASSWORD
# 範例: CB_TOKEN=your_api_token
# CB_TOKEN=

# ============================================================
# Tracker 與分頁
# -----------------------------------------
# 【教學】ID、SIZE 如何取得：
#
#  ● CB_TRACKER_ID（Tracker ID）
#    1. 在 Codebeamer 開啟目標專案，點進要讀取的「Tracker」（例如規格書的 tracker）。
#    2. 看瀏覽器網址列，格式通常為：
#       https://xxx/cb/project/專案id#tracker=12096
#       或 .../trackers/12096/... 或 ...trackerId=12096
#    3. 網址中的那串數字（本例 12096）即為 CB_TRACKER_ID。
#
#  ● CB_TEST_ITEM_ID（單一 Item ID）
#    1. 在該 tracker 裡點開「任一 work item」（例如某一章或某一個 component）。
#    2. 看該筆 item 的網址，常見格式：
#       https://xxx/cb/item/7210  或  .../items/7210  或  ...id=7210
#    3. 網址中的那串數字（本例 7210）即為 CB_TEST_ITEM_ID。
#    程式會用這筆來測試連線並印出 JSON，可填該 tracker 內任意一筆 item 的 id。
#
#  ● CB_PAGE_SIZE（每頁筆數）
#    不必從 Codebeamer 取得。掃描整個 tracker 時，API 會分頁回傳，這裡設定「每頁幾筆」。
#    建議值 100；若 tracker 很大可填 200，不影響結果，只影響單次請求筆數。
# -----------------------------------------
# 範例: CB_TRACKER_ID=12096
CB_TRACKER_ID=0

# 範例: CB_PAGE_SIZE=100
CB_PAGE_SIZE=100

# 範例: CB_TEST_ITEM_ID=7210
CB_TEST_ITEM_ID=0

# CB_TRACKER_ITEMS_URL= （選填，通常留空）

# ============================================================
# 列出項目：要抓哪些、要不要展開子層
# ============================================================
# 範例: CB_LIST_FIRST_LEVEL_ONLY=1
CB_LIST_FIRST_LEVEL_ONLY=1

# 範例: CB_TARGET_COMPONENT_NAMES=HwCom_81; [SWITCH] top view
CB_TARGET_COMPONENT_NAMES=

# CB_LIST_FIRST_N=50 （除錯用，選填）
